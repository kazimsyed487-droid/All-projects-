<!-- YouTube and Slider JavaScript Logic -->
<script src="https://www.youtube.com/iframe_api"></script>
<script>
  let player;
  let isPlaying = false;
  const toggleBtn = document.getElementById('musicToggleBtn');
  
  function onYouTubeIframeAPIReady() {
    player = new YT.Player('yt-player', {
      height: '1',
      width: '1',
      videoId: 'SHO8XkOloBM',
      playerVars: {
        'start': 87, // Exact 1:27 ("Dil e tute hue hai qayamat...")
        'controls': 0,
        'disablekb': 1,
        'modestbranding': 1,
        'rel': 0
      },
      events: { 'onReady': onPlayerReady }
    });
  }

  function onPlayerReady(event) {}

  function toggleMusic() {
    if (!player || typeof player.playVideo !== 'function') return;
    if (!isPlaying) {
      player.seekTo(87, true);
      player.playVideo();
      toggleBtn.innerHTML = "⏸️ Pause Music";
      isPlaying = true;
    } else {
      player.pauseVideo();
      toggleBtn.innerHTML = "▶️ Play Music";
      isPlaying = false;
    }
  }

  function slideImg(index) {
    const slider = document.getElementById('sliderObj');
    if(index === 1) {
      slider.style.transform = "translateX(-50%)"; 
    } else {
      slider.style.transform = "translateX(0%)"; 
    }
  }

  document.querySelectorAll('input[name="card-nav"]').forEach(radio => {
    radio.addEventListener('change', () => {
      if (player && typeof player.playVideo === 'function' && isPlaying) {
        player.playVideo(); 
      }
    });
  });
</script>

