<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Best Friend Day! 🫶💖</title>
<style>
  /* Global Page Design & Animated Background */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: linear-gradient(135deg, #120c1f, #2a1b4e, #5a189a, #7b2cbf);
    background-size: 400% 400%;
    animation: gradientBG 10s ease infinite;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 15px;
  }
  @keyframes gradientBG {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Card Container Design */
  .card-container {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: 100%;
    max-width: 450px;
    border-radius: 24px;
    padding: 25px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    text-align: center;
    position: relative;
  }

  input[type="radio"] { display: none; }
  .page { display: none; animation: fadeIn 0.4s ease-in-out forwards; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Tab Navigation Mechanics */
  #tab1:checked ~ .card-container #page1,
  #tab2:checked ~ .card-container #page2,
  #tab3:checked ~ .card-container #page3 { display: block; }

  /* Navigation Buttons */
  .nav-btn {
    display: inline-block;
    background: linear-gradient(45deg, #9d4edd, #e0aaff);
    color: #120c1f;
    padding: 12px 24px;
    font-weight: bold;
    border-radius: 50px;
    cursor: pointer;
    margin-top: 15px;
    transition: 0.3s transform ease;
    font-size: 13px;
    text-transform: uppercase;
    border: none;
  }
  .nav-btn:hover { transform: scale(1.03); }

  /* Custom Music Control Button */
  .play-control-btn {
    display: inline-block;
    background: linear-gradient(45deg, #ff477e, #ff7096);
    color: #fff;
    padding: 10px 20px;
    font-weight: bold;
    border-radius: 50px;
    cursor: pointer;
    margin-bottom: 15px;
    transition: 0.3s all ease;
    font-size: 12px;
    text-transform: uppercase;
    border: none;
    box-shadow: 0 4px 15px rgba(255, 71, 126, 0.4);
  }
  .play-control-btn:hover {
    transform: scale(1.03);
    box-shadow: 0 6px 20px rgba(255, 71, 126, 0.6);
  }

  h1 { font-size: 1.5rem; margin-bottom: 15px; color: #e0aaff; text-shadow: 0 0 10px rgba(224, 170, 255, 0.4); white-space: nowrap; }
  
  .custom-message {
    font-size: 0.95rem;
    line-height: 1.6;
    background: rgba(0, 0, 0, 0.3);
    padding: 18px;
    border-radius: 16px;
    margin: 15px 0;
    border-left: 4px solid #9d4edd;
    text-align: center;
  }

  /* Fixed Size Media Frame */
  .media-box {
    width: 100%;
    height: 300px; 
    border-radius: 16px;
    margin: 15px 0;
    overflow: hidden; 
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.2);
    position: relative;
  }
  .media-box img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover; 
  }

  /* Fixed Size Slider Frame for Page 2 */
  .slider-wrapper {
    position: relative;
    width: 100%;
    height: 300px; 
    margin: 15px 0;
    overflow: hidden; 
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.2);
  }
  .image-slider {
    display: flex;
    width: 200%; 
    height: 100%;
    transition: transform 0.5s ease-in-out;
  }
  .slider-img {
    width: 50%; 
    height: 100%;
    object-fit: cover; 
    background: rgba(0,0,0,0.2);
  }
  .slider-arrows {
    position: absolute;
    top: 50%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    transform: translateY(-50%);
    padding: 0 10px;
    pointer-events: none;
  }
  .arrow {
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    border: none;
    width: 35px;
    height: 35px;
    border-radius: 50%;
    cursor: pointer;
    font-weight: bold;
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 10px rgba(0,0,0,0.5);
  }

  /* Footer and Branding Tags */
  .music-container {
    background: rgba(0, 0, 0, 0.4);
    padding: 10px 15px;
    border-radius: 50px;
    margin-bottom: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .music-title { font-size: 12px; color: #e0aaff; font-weight: bold; }
  .special-quote {
    font-style: italic;
    font-size: 0.95rem;
    color: #fff;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 1px dashed rgba(255, 255, 255, 0.2);
    text-shadow: 0 0 8px rgba(255,255,255,0.5);
  }

  .execution-tag {
    background: linear-gradient(135deg, rgba(0, 242, 254, 0.15), rgba(79, 172, 254, 0.25));
    border: 1px solid #4facfe;
    border-radius: 12px;
    padding: 12px;
    margin-top: 25px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
    letter-spacing: 1px;
    color: #00f2fe;
    box-shadow: 0 0 15px rgba(0, 242, 254, 0.3);
    text-shadow: 0 0 8px rgba(0, 242, 254, 0.6);
    display: inline-block;
    width: 100%;
  }
  .execution-tag span {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: #fff;
    font-weight: bold;
    display: block;
    margin-top: 4px;
    font-size: 1.1rem;
    text-shadow: 0 0 10px #e0aaff;
  }

  #yt-player { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
</style>
</head>
